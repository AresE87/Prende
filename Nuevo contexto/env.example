# ─── SUPABASE ──────────────────────────────────────────────────────────────────
VITE_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Solo en Edge Functions / servidor — NUNCA en frontend
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ─── MERCADOPAGO ───────────────────────────────────────────────────────────────
# Público: va en frontend (VITE_ prefix para que Vite lo exponga)
VITE_MP_PUBLIC_KEY=APP_USR-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# Privados: SOLO en Edge Functions
MP_ACCESS_TOKEN=APP_USR-0000000000000000-000000-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx-000000000
MP_WEBHOOK_SECRET=tu_webhook_secret_generado_en_mp_dashboard

# URL base del backend para que MP sepa dónde enviar los webhooks
# En producción: https://xxxxxxxxxxxx.supabase.co/functions/v1
# En local: usa ngrok o supabase functions serve
MP_WEBHOOK_URL=https://xxxxxxxxxxxx.supabase.co/functions/v1/mp-webhook

# ─── WHATSAPP / 360DIALOG ──────────────────────────────────────────────────────
# Obtener en: app.360dialog.com → Developer → API Keys
WA_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
WA_PHONE_NUMBER_ID=1234567890123456

# ─── GOOGLE MAPS ───────────────────────────────────────────────────────────────
# Crear en: console.cloud.google.com → Credentials
# Restringir a: Maps JS API, Places API, Geocoding API
# Restringir HTTP referrers a: localhost, prende.uy, *.prende.uy
VITE_GOOGLE_MAPS_API_KEY=AIzaSyXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# ─── RESEND (EMAIL) ────────────────────────────────────────────────────────────
# Obtener en: resend.com → API Keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
RESEND_FROM_EMAIL=reservas@prende.uy

# ─── APP CONFIG ────────────────────────────────────────────────────────────────
VITE_APP_URL=https://prende.uy
VITE_TAKE_RATE=0.15
# Días de retención antes de liberar pago al host (0 = inmediato post-evento)
PAYMENT_RELEASE_DELAY_DAYS=1
